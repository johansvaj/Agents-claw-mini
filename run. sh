#!/bin/bash
# Nexcorix Claw - Auto Setup & Run Script (Deteksi OS, venv, install library hanya jika belum ada)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}[*] Nexcorix Claw Setup Script${NC}"

# Deteksi OS
OS="$(uname -s)"
case "$OS" in
    Linux*)     OS_TYPE="Linux";;
    Darwin*)    OS_TYPE="Mac";;
    MINGW*|CYGWIN*|MSYS*) OS_TYPE="Windows";;
    *)          OS_TYPE="Unknown";;
esac
echo -e "[+] Detected OS: $OS_TYPE"

# Deteksi distro Linux
DISTRO="unknown"
if [ "$OS_TYPE" = "Linux" ] && [ -f /etc/os-release ]; then
    . /etc/os-release
    DISTRO="$ID"
    echo -e "[+] Distribution: $DISTRO $VERSION_ID"
fi

# Cek Python3
if ! command -v python3 &> /dev/null; then
    echo -e "${RED}[-] Python3 not found. Please install Python 3.8+${NC}"
    exit 1
fi

# Fungsi install apt package (Debian/Ubuntu/Kali)
install_apt_pkg() {
    local pkg="$1"
    if ! dpkg -l | grep -q "^ii  $pkg "; then
        echo -e "${YELLOW}[!] Installing $pkg via apt...${NC}"
        sudo apt update && sudo apt install -y "$pkg"
    else
        echo -e "[+] $pkg already installed"
    fi
}

# Pastikan venv module tersedia (khusus Linux dengan external management)
if [ "$OS_TYPE" = "Linux" ] && [ "$DISTRO" = "kali" -o "$DISTRO" = "debian" -o "$DISTRO" = "ubuntu" ]; then
    if ! python3 -c "import venv" &>/dev/null; then
        echo -e "${YELLOW}[!] python3-venv not found, installing...${NC}"
        install_apt_pkg python3-venv
    fi
fi

# Buat virtual environment jika belum ada
if [ ! -d "venv" ]; then
    echo -e "${YELLOW}[!] Creating virtual environment...${NC}"
    python3 -m venv venv
    echo -e "${GREEN}[✓] Virtual environment created${NC}"
else
    echo -e "[+] Using existing virtual environment"
fi

# Aktifkan venv
source venv/bin/activate

# Upgrade pip di venv
pip install --upgrade pip >/dev/null 2>&1

# Install dependencies hanya jika belum terinstall (cek via pip list)
echo -e "[*] Checking required Python packages..."
PACKAGES=("psutil" "python-telegram-bot" "discord.py" "slack-sdk" "matrix-nio" "google-api-python-client" "dropbox" "PyGithub" "python-gitlab" "notion-client" "py-trello" "jira" "pyairtable" "psycopg2-binary" "mysql-connector-python" "pymongo" "redis" "paho-mqtt" "pywhatsapp")
for pkg in "${PACKAGES[@]}"; do
    if pip show "$pkg" &>/dev/null; then
        echo -e "[+] $pkg already installed"
    else
        echo -e "${YELLOW}[!] Installing $pkg...${NC}"
        pip install "$pkg"
    fi
done

# Jalankan program
echo -e "${GREEN}[✓] Starting Nexcorix Claw...${NC}"
python3 nexcorix_claw.py

# Deaktivasi venv setelah program selesai
deactivate
